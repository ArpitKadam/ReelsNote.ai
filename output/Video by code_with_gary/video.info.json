ram.fpnq7-2.fna&_nc_gid=xan55UFIGW48mXRl757Z0w&_nc_ss=7d689&oh=00_AQDMyK2W2-_zky3bI6zUyeD1oUfpYs2RUXRn--kch7ve_w&oe=6A5AFF78", "width": 1080, "height": 1080, "id": "11", "resolution": "1080x1080"}, {"url": "https://instagram.fpnq7-2.fna.fbcdn.net/v/t51.82787-15/686976790_18070856315450325_6056907497791667888_n.jpg?stp=dst-jpg_e35_p1080x1080_sh2.08_tt6&_nc_cat=102&ig_cache_key=Mzg5MjE1NDM3NjE0Njg0ODQ3NjE4MDcwODU2MzA5NDUwMzI1.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6IkNMSVBTLnhwaWRzLjEyOTAuc2RyLnZpZGVvX2RlZmF1bHRfY292ZXJfZnJhbWUuQzMifQ%3D%3D&_nc_ohc=KgcH_EgqEzMQ7kNvwE2lPAM&_nc_oc=AdrFaYjej6v7EKQqx9B5wazfC7tD8Tpa6T5f0JNmdLoKGfw4HjV7w5fSWvnCETEQokOwYlEKRnVz4zor2T4Fe4V0&_nc_zt=23&_nc_ht=instagram.fpnq7-2.fna&_nc_gid=xan55UFIGW48mXRl757Z0w&_nc_ss=7d689&oh=00_AQAi2LtSLZBD2R5LvztENzezaVOsKTp0SlBKisLtK56TVw&oe=6A5AFF78", "width": 1080, "height": 1921, "id": "12", "resolution": "1080x1921"}, {"url": "https://instagram.fpnq7-2.fna.fbcdn.net/v/t51.82787-15/686976790_18070856315450325_6056907497791667888_n.jpg?stp=dst-jpg_e15_tt6&_nc_cat=102&ig_cache_key=Mzg5MjE1NDM3NjE0Njg0ODQ3NjE4MDcwODU2MzA5NDUwMzI1.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6IkNMSVBTLnhwaWRzLjEyOTAuc2RyLnZpZGVvX2RlZmF1bHRfY292ZXJfZnJhbWUuQzMifQ%3D%3D&_nc_ohc=KgcH_EgqEzMQ7kNvwE2lPAM&_nc_oc=AdrFaYjej6v7EKQqx9B5wazfC7tD8Tpa6T5f0JNmdLoKGfw4HjV7w5fSWvnCETEQokOwYlEKRnVz4zor2T4Fe4V0&_nc_zt=23&_nc_ht=instagram.fpnq7-2.fna&_nc_gid=xan55UFIGW48mXRl757Z0w&_nc_ss=7d689&oh=00_AQA48jgE-ZDeGBRYwZpcsfvf1cuUkOT64ODCZjBU_RtM9A&oe=6A5AFF78", "width": 1290, "height": 2294, "id": "13", "resolution": "1290x2294"}], "comments": [{"author": "scorpioc84", "author_id": "23957611650", "id": "17942453661294412", "text": "148257", "timestamp": 1783454021, "like_count": 0}, {"author": "rajesh29232923", "author_id": "73542539248", "id": "18397427479090885", "text": "👏", "timestamp": 1783395267, "like_count": 0}, {"author": "tauber_schlumpf", "author_id": "225530103", "id": "18088648094636437", "text": "there is nothing true in here and you disnt even bother to really animate anything. what the fuck is this?", "timestamp": 1782028282, "like_count": 0}, {"author": "sayyedhidayath", "author_id": "8036929886", "id": "18112814416781826", "text": "😍", "timestamp": 1781994058, "like_count": 0}, {"author": "kiran_kumarcmg", "author_id": "22435948018", "id": "18223659496318070", "text": "🙌", "timestamp": 1781495185, "like_count": 0}, {"author": "divyanshuaaryan", "author_id": "3595826199", "id": "18068177462383090", "text": "Just maintaining create date of documents if same file again upload with different date it auto delete all old data and replace with new file data🫠", "timestamp": 1781451989, "like_count": 0}, {"author": "basha5131", "author_id": "8496081525", "id": "18125700604726583", "text": "🙌", "timestamp": 1780863646, "like_count": 0}, {"author": "ayan1742194", "author_id": "78041104614", "id": "18130834636578493", "text": "Add logs to the data change and then chunk - embed - store again. Don't overwrite the previous vectors", "timestamp": 1780586004, "like_count": 1}, {"author": "_sunil.lol", "author_id": "4936574993", "id": "18325786309251209", "text": "maintain hash id for every data or files", "timestamp": 1779981395, "like_count": 0}, {"author": "tulasiram574", "author_id": "1903459845", "id": "18103955857799209", "text": "Simplest way is batch wise data versioning at tool level. When new data arrives drive that to a new storage location. Later ingest both into RAG pipeline. Similarly flow goes this will increase throughput and reduce latency as well.", "timestamp": 1779159410, "like_count": 2}, {"author": "therealswatijain", "author_id": "2252370023", "id": "18108176272907196", "text": "👏👏👏", "timestamp": 1778528246, "like_count": 0}, {"author": "itsmanishkumarpandey", "author_id": "10934706569", "id": "18092098697240268", "text": "🙌", "timestamp": 1778384320, "like_count": 0}, {"author": "nategood", "author_id": "37419885", "id": "18120440167662017", "text": "Seems wildly inefficient. Clone the entire file with each version? Rebuild the entire index? If so, there are much better solutions.", "timestamp": 1778342002, "like_count": 2}, {"author": "industryplantcore", "author_id": "70730334381", "id": "18104090450480789", "text": "append-only writes, chunking subroutines to index & verify new versions, then atomic swap published version & fresh+valid version", "timestamp": 1778201635, "like_count": 5}, {"author": "code_with_gary", "author_id": "43532890324", "id": "17900824749429546", "text": "Use Index Aliasing. Build your new knowledge base version in a separate index. Once it's validated, point your application to the new index. It’s an atomic swap that gives you zero downtime and an instant rollback if things go wrong. \n\nYou have 1 million vectors and need to update just 10 documents. Do you trigger a full re-index or do an incremental update? Tell me your choice in the comments! 👇\n\n#rag #ai #systemdesign #llm #backend #softwareengineering #machinelearning #coding #techinterviews #developer", "timestamp": 1778201154, "like_count": 30}], "webpage_url": "https://www.instagram.com/reel/DYDtciZNwrc/?utm_source=ig_web_copy_link&igsh=MzRlODBiNWFlZA==", "webpage_url_basename": "DYDtciZNwrc", "webpage_url_domain": "instagram.com", "extractor": "Instagram", "extractor_key": "Instagram", "thumbnail": "https://instagram.fpnq7-2.fna.fbcdn.net/v/t51.82787-15/686976790_18070856315450325_6056907497791667888_n.jpg?stp=dst-jpg_e15_tt6&_nc_cat=102&ig_cache_key=Mzg5MjE1NDM3NjE0Njg0ODQ3NjE4MDcwODU2MzA5NDUwMzI1.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6IkNMSVBTLnhwaWRzLjEyOTAuc2RyLnZpZGVvX2RlZmF1bHRfY292ZXJfZnJhbWUuQzMifQ%3D%3D&_nc_ohc=KgcH_EgqEzMQ7kNvwE2lPAM&_nc_oc=AdrFaYjej6v7EKQqx9B5wazfC7tD8Tpa6T5f0JNmdLoKGfw4HjV7w5fSWvnCETEQokOwYlEKRnVz4zor2T4Fe4V0&_nc_zt=23&_nc_ht=instagram.fpnq7-2.fna&_nc_gid=xan55UFIGW48mXRl757Z0w&_nc_ss=7d689&oh=00_AQA48jgE-ZDeGBRYwZpcsfvf1cuUkOT64ODCZjBU_RtM9A&oe=6A5AFF78", "display_id": "DYDtciZNwrc"